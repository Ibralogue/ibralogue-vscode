{
  "New Conversation": {
    "prefix": "conv",
    "body": [
      "{{ConversationName(${1:Name})}}",
      "[${2:Speaker}]",
      "${3:Dialogue text}",
      "$0"
    ],
    "description": "New conversation block"
  },
  "Speaker Line": {
    "prefix": "speak",
    "body": [
      "[${1:Speaker}]",
      "${2:Dialogue text}",
      "$0"
    ],
    "description": "New speaker with dialogue"
  },
  "Silent Line": {
    "prefix": "silent",
    "body": [
      "[>>]",
      "${1:{{FunctionName}}}",
      "$0"
    ],
    "description": "Silent line that runs invocations without showing dialogue"
  },
  "Choice": {
    "prefix": "choice",
    "body": [
      "- ${1:Choice text} -> ${2:TargetConversation}$0"
    ],
    "description": "Choice declaration"
  },
  "Continue Choice": {
    "prefix": "choicec",
    "body": [
      "- ${1:Choice text} -> >>$0"
    ],
    "description": "Choice that continues in the current conversation"
  },
  "Choice with Metadata": {
    "prefix": "choicem",
    "body": [
      "- ${1:Choice text} -> ${2:TargetConversation} ## ${3:key}:${4:value}$0"
    ],
    "description": "Choice with metadata"
  },
  "If/Else/EndIf": {
    "prefix": "if",
    "body": [
      "{{If(${1:condition})}}",
      "${2:content}",
      "{{Else}}",
      "${3:alternate}",
      "{{EndIf}}",
      "$0"
    ],
    "description": "Conditional block with If/Else"
  },
  "If/EndIf": {
    "prefix": "iff",
    "body": [
      "{{If(${1:condition})}}",
      "${2:content}",
      "{{EndIf}}",
      "$0"
    ],
    "description": "Conditional block without Else"
  },
  "ElseIf": {
    "prefix": "elif",
    "body": [
      "{{ElseIf(${1:condition})}}",
      "$0"
    ],
    "description": "ElseIf branch"
  },
  "Set Variable": {
    "prefix": "set",
    "body": [
      "{{Set(\\$${1:VARIABLE}, ${2:value})}}$0"
    ],
    "description": "Assign a variable value"
  },
  "Global Variable": {
    "prefix": "global",
    "body": [
      "{{Global(\\$${1:VARIABLE}, ${2:value})}}$0"
    ],
    "description": "Declare a global variable"
  },
  "Jump": {
    "prefix": "jump",
    "body": [
      "{{Jump(${1:TargetConversation})}}$0"
    ],
    "description": "Jump to another conversation"
  },
  "Image": {
    "prefix": "image",
    "body": [
      "{{Image(${1:Sprites/Path})}}$0"
    ],
    "description": "Set speaker portrait"
  },
  "Audio": {
    "prefix": "audio",
    "body": [
      "{{Audio(${1:ClipId})}}$0"
    ],
    "description": "Play an audio clip"
  },
  "Wait": {
    "prefix": "wait",
    "body": [
      "{{Wait(${1:seconds})}}$0"
    ],
    "description": "Pause display for a duration"
  },
  "Speed": {
    "prefix": "speed",
    "body": [
      "{{Speed(${1:multiplier})}}$0"
    ],
    "description": "Change text reveal speed"
  },
  "Include": {
    "prefix": "include",
    "body": [
      "{{Include(${1:AssetName})}}$0"
    ],
    "description": "Include another dialogue file"
  },
  "Include Conversation": {
    "prefix": "includec",
    "body": [
      "{{Include(${1:AssetName}, ${2:ConversationName})}}$0"
    ],
    "description": "Include a specific conversation from another file"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "{{${1:FunctionName}($2)}}$0"
    ],
    "description": "Inline function invocation"
  },
  "Variable": {
    "prefix": "var",
    "body": [
      "\\$${1:VARIABLENAME}$0"
    ],
    "description": "Variable reference"
  },
  "Metadata": {
    "prefix": "meta",
    "body": [
      "## ${1:key}:${2:value}$0"
    ],
    "description": "Metadata annotation"
  },
  "Branching Dialogue": {
    "prefix": "branch",
    "body": [
      "{{ConversationName(${1:Initial})}}",
      "[${2:NPC}]",
      "${3:Question text}",
      "- ${4:Choice A} -> ${5:ConversationA}",
      "- ${6:Choice B} -> ${7:ConversationB}",
      "",
      "{{ConversationName(${5:ConversationA})}}",
      "[${2:NPC}]",
      "${8:Response A}",
      "",
      "{{ConversationName(${7:ConversationB})}}",
      "[${2:NPC}]",
      "${9:Response B}",
      "$0"
    ],
    "description": "Complete branching dialogue with two choices"
  }
}
