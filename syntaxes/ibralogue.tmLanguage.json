{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ibralogue",
  "scopeName": "source.ibralogue",
  "patterns": [
    { "include": "#comment" },
    { "include": "#conversationCommand" },
    { "include": "#conditionalCommand" },
    { "include": "#variableCommand" },
    { "include": "#builtinCommand" },
    { "include": "#includeCommand" },
    { "include": "#speaker" },
    { "include": "#choice" },
    { "include": "#textLine" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*(#)(?!#)(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.comment.ibralogue" },
        "2": { "name": "comment.line.number-sign.ibralogue" }
      }
    },

    "conversationCommand": {
      "match": "^\\s*(\\{\\{)(ConversationName)(\\()([^)]*)(\\))(\\}\\})\\s*$",
      "captures": {
        "1": { "name": "punctuation.definition.command.begin.ibralogue" },
        "2": { "name": "keyword.control.conversation.ibralogue" },
        "3": { "name": "punctuation.parenthesis.open.ibralogue" },
        "4": { "name": "entity.name.section.conversation.ibralogue" },
        "5": { "name": "punctuation.parenthesis.close.ibralogue" },
        "6": { "name": "punctuation.definition.command.end.ibralogue" }
      }
    },

    "conditionalCommand": {
      "patterns": [
        {
          "comment": "{{If(expr)}} and {{ElseIf(expr)}} with parenthesised condition",
          "match": "^\\s*(\\{\\{)(If|ElseIf)(\\()(.+)(\\))(\\}\\})\\s*$",
          "captures": {
            "1": { "name": "punctuation.definition.command.begin.ibralogue" },
            "2": { "name": "keyword.control.conditional.ibralogue" },
            "3": { "name": "punctuation.parenthesis.open.ibralogue" },
            "4": {
              "name": "meta.expression.ibralogue",
              "patterns": [
                { "include": "#expressionOperator" },
                { "include": "#expressionLiteral" },
                { "include": "#variable" }
              ]
            },
            "5": { "name": "punctuation.parenthesis.close.ibralogue" },
            "6": { "name": "punctuation.definition.command.end.ibralogue" }
          }
        },
        {
          "comment": "{{Else}} and {{EndIf}} — no arguments",
          "match": "^\\s*(\\{\\{)(Else|EndIf)(\\}\\})\\s*$",
          "captures": {
            "1": { "name": "punctuation.definition.command.begin.ibralogue" },
            "2": { "name": "keyword.control.conditional.ibralogue" },
            "3": { "name": "punctuation.definition.command.end.ibralogue" }
          }
        }
      ]
    },

    "variableCommand": {
      "patterns": [
        {
          "comment": "{{Set($Var, expr)}}",
          "match": "^\\s*(\\{\\{)(Set)(\\()(.+)(\\))(\\}\\})\\s*$",
          "captures": {
            "1": { "name": "punctuation.definition.command.begin.ibralogue" },
            "2": { "name": "keyword.control.variable.ibralogue" },
            "3": { "name": "punctuation.parenthesis.open.ibralogue" },
            "4": {
              "name": "meta.arguments.ibralogue",
              "patterns": [
                { "include": "#variable" },
                { "include": "#expressionOperator" },
                { "include": "#expressionLiteral" }
              ]
            },
            "5": { "name": "punctuation.parenthesis.close.ibralogue" },
            "6": { "name": "punctuation.definition.command.end.ibralogue" }
          }
        },
        {
          "comment": "{{Global($Var)}} or {{Global($Var, expr)}}",
          "match": "^\\s*(\\{\\{)(Global)(\\()(.+)(\\))(\\}\\})\\s*$",
          "captures": {
            "1": { "name": "punctuation.definition.command.begin.ibralogue" },
            "2": { "name": "keyword.control.variable.ibralogue" },
            "3": { "name": "punctuation.parenthesis.open.ibralogue" },
            "4": {
              "name": "meta.arguments.ibralogue",
              "patterns": [
                { "include": "#variable" },
                { "include": "#expressionOperator" },
                { "include": "#expressionLiteral" }
              ]
            },
            "5": { "name": "punctuation.parenthesis.close.ibralogue" },
            "6": { "name": "punctuation.definition.command.end.ibralogue" }
          }
        }
      ]
    },

    "builtinCommand": {
      "match": "^\\s*(\\{\\{)(Jump|Image|Audio|Wait|Speed)(\\()([^)]*)(\\))(\\}\\})\\s*$",
      "captures": {
        "1": { "name": "punctuation.definition.command.begin.ibralogue" },
        "2": { "name": "keyword.control.builtin.ibralogue" },
        "3": { "name": "punctuation.parenthesis.open.ibralogue" },
        "4": {
          "name": "string.unquoted.argument.ibralogue",
          "patterns": [{ "include": "#variable" }]
        },
        "5": { "name": "punctuation.parenthesis.close.ibralogue" },
        "6": { "name": "punctuation.definition.command.end.ibralogue" }
      }
    },

    "includeCommand": {
      "match": "^\\s*(\\{\\{)(Include)(\\()([^)]*)(\\))(\\}\\})\\s*$",
      "captures": {
        "1": { "name": "punctuation.definition.command.begin.ibralogue" },
        "2": { "name": "keyword.control.include.ibralogue" },
        "3": { "name": "punctuation.parenthesis.open.ibralogue" },
        "4": { "name": "string.unquoted.path.ibralogue" },
        "5": { "name": "punctuation.parenthesis.close.ibralogue" },
        "6": { "name": "punctuation.definition.command.end.ibralogue" }
      }
    },

    "speaker": {
      "match": "^\\s*(\\[)([^\\]]*)(\\])",
      "captures": {
        "1": { "name": "punctuation.definition.speaker.begin.ibralogue" },
        "2": {
          "name": "entity.name.tag.speaker.ibralogue",
          "patterns": [{ "include": "#variable" }]
        },
        "3": { "name": "punctuation.definition.speaker.end.ibralogue" }
      }
    },

    "choice": {
      "match": "^\\s*(-)\\s+(.*?)(\\s*->\\s*)(\\S+)(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.choice.ibralogue" },
        "2": {
          "name": "string.unquoted.choice-text.ibralogue",
          "patterns": [{ "include": "#variable" }]
        },
        "3": { "name": "keyword.operator.arrow.ibralogue" },
        "4": {
          "name": "entity.name.section.choice-target.ibralogue",
          "patterns": [{ "include": "#variable" }]
        },
        "5": { "patterns": [{ "include": "#trailingMetadata" }] }
      }
    },

    "textLine": {
      "begin": "^(?!\\s*#)(?!\\s*\\[)(?!\\s*-)(?!\\s*\\{\\{(?:ConversationName|Jump|Image|Include|Audio|Wait|Speed|If|ElseIf|Else|EndIf|Set|Global)(?:[({])?)(?!\\s*\\{\\{(?:Else|EndIf)\\}\\})(?=\\S)",
      "end": "$",
      "patterns": [
        { "include": "#escapeSequence" },
        { "include": "#trailingMetadata" },
        { "include": "#inlineFunction" },
        { "include": "#variable" },
        { "include": "#richTextTag" }
      ]
    },

    "inlineFunction": {
      "match": "(\\{\\{)([^}(]+)(?:(\\()([^)]*)(\\)))?(\\}\\})",
      "captures": {
        "1": { "name": "punctuation.definition.function.begin.ibralogue" },
        "2": { "name": "entity.name.function.ibralogue" },
        "3": { "name": "punctuation.parenthesis.open.ibralogue" },
        "4": {
          "name": "variable.parameter.function.ibralogue",
          "patterns": [{ "include": "#variable" }]
        },
        "5": { "name": "punctuation.parenthesis.close.ibralogue" },
        "6": { "name": "punctuation.definition.function.end.ibralogue" }
      }
    },

    "variable": {
      "match": "(\\$)([a-zA-Z0-9_]+)",
      "captures": {
        "1": { "name": "punctuation.definition.variable.ibralogue" },
        "2": { "name": "variable.other.global.ibralogue" }
      }
    },

    "expressionOperator": {
      "match": "\\b(AND|OR|NOT)\\b|[=!<>]=?|[+\\-*/]",
      "name": "keyword.operator.expression.ibralogue"
    },

    "expressionLiteral": {
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.ibralogue"
        },
        {
          "match": "\\b\\d+(\\.\\d+)?\\b",
          "name": "constant.numeric.ibralogue"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.ibralogue"
        }
      ]
    },

    "trailingMetadata": {
      "match": "(##)\\s*(.*?)\\s*$",
      "captures": {
        "1": { "name": "punctuation.definition.metadata.ibralogue" },
        "2": {
          "name": "comment.block.metadata.ibralogue",
          "patterns": [
            {
              "match": "([^:\\s]+)(:)([^\\s]+)",
              "captures": {
                "1": { "name": "entity.other.attribute-name.metadata-key.ibralogue" },
                "2": { "name": "punctuation.separator.colon.ibralogue" },
                "3": {
                  "name": "string.unquoted.metadata-value.ibralogue",
                  "patterns": [{ "include": "#variable" }]
                }
              }
            },
            {
              "match": "[^\\s:]+",
              "name": "entity.other.attribute-name.metadata-tag.ibralogue"
            }
          ]
        }
      }
    },

    "escapeSequence": {
      "match": "\\\\(\\{\\{|\\$|##|#|\\[|\\-|\\\\)",
      "name": "constant.character.escape.ibralogue"
    },

    "richTextTag": {
      "match": "</?[a-zA-Z][^>]*>",
      "name": "meta.tag.richtext.ibralogue"
    }
  }
}
