{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["{{", "}}"],
    ["(", ")"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "{{", "close": "}}" },
    { "open": "(", "close": ")" },
    { "open": "<", "close": ">" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["<", ">"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\\{\\{ConversationName\\(",
      "end": "^(?=\\s*\\{\\{ConversationName\\()"
    }
  },
  "wordPattern": "[a-zA-Z0-9_$]+",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*\\[.+\\]\\s*$",
    "decreaseIndentPattern": "^$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\[.+\\]\\s*$",
      "action": { "indent": "none" }
    },
    {
      "beforeText": "^\\s*-\\s+.+->.*$",
      "action": { "indent": "none" }
    }
  ]
}
